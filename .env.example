# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-secret-key
BETTER_AUTH_URL=http://localhost:3000
AUTH_EMAIL_FROM_NAME=SpotMe
AUTH_EMAIL_FROM_ADDRESS=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=spotme
R2_PUBLIC_URL=https://your-bucket.r2.dev

# AI Service (Hugging Face Spaces — mock for now)
AI_SERVICE_URL=http://localhost:3000/api/mock-match
AI_SERVICE_API_KEY=your-ai-service-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=spotme

# Cron
CRON_SECRET=generate-a-random-cron-secret
